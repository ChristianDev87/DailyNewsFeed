#!/bin/bash
# Deploy-Script für den Discord-Bot (Docker-Container)
#
# Voraussetzungen auf dem Host:
#   - git
#   - docker + docker compose (Plugin, nicht standalone)
#   - Projekt liegt unter /opt/daily-news (PROJECT_DIR anpassen falls abweichend)
#
# Einrichten:
#   cp deploy-bot.sh.example deploy-bot.sh
#   chmod +x deploy-bot.sh
#
set -e
PROJ=/opt/daily-news
cd "$PROJ"

echo "=== Bot deployen ==="
git pull origin main
docker compose build bot
docker compose up -d --no-deps bot
echo "=== Bot: Fertig ==="
