# ================================
# DailyNewsFeed — Konfiguration
# Kopieren: cp .env.example .env
# ================================

# -----------------------------------------------
# Datenbank — eine Option wählen:
#
# Option A: Externe MariaDB (bereits vorhanden)
#   DB_HOST=dein-datenbankserver
#
# Option B: MariaDB im Docker
#   docker compose --profile with-db up -d
#   DB_HOST=db               ← Docker-interner Hostname für Bot & Frontend
#   DB_ROOT_PASS=...         ← Root-Passwort für den DB-Container
#   WATCHDOG_DB_HOST=127.0.0.1  ← Watchdog läuft auf dem Host
#   WATCHDOG_DB_PORT=3307    ← Container ist auf Host-Port 3307 erreichbar (nicht 3306)
# -----------------------------------------------

DB_HOST=localhost
DB_PORT=3306
DB_NAME=daily_news
DB_USER=daily_news
DB_PASS=changeme
# DB_ROOT_PASS=changeme          # nur Option B — Root-Passwort für den MariaDB-Container
# WATCHDOG_DB_HOST=127.0.0.1    # nur Option B — überschreibt DB_HOST für den Watchdog
# WATCHDOG_DB_PORT=3307          # nur Option B — Container auf Host-Port 3307 erreichbar

# Discord Bot Token
DISCORD_TOKEN=

# Verschlüsselung für Custom Bot Tokens (AES-256, min. 32 Zeichen)
TOKEN_ENCRYPTION_KEY=

# Discord OAuth2 (Frontend)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-domain.com/auth/callback

# Frontend
APP_URL=https://your-domain.com
APP_SECRET=changeme-random-string-min-32-chars

# Logging
LOG_LEVEL=Information
