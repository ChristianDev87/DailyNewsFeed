# ================================
# DailyNewsFeed — Konfiguration
# Kopieren: cp .env.example .env
# ================================

# Datenbank (Option A — externe MariaDB)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dailynews
DB_USER=dailynews
DB_PASS=changeme

# Discord Bot Token
DISCORD_TOKEN=

# Verschlüsselung für Custom Bot Tokens (AES-256, min. 32 Zeichen)
TOKEN_ENCRYPTION_KEY=

# Discord OAuth2 (Frontend)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://your-domain.com/auth/callback

# Frontend
APP_URL=https://your-domain.com
APP_SECRET=changeme-random-string-min-32-chars

# Logging
LOG_LEVEL=Information
